#N canvas 60 60 720 560 10;
#X obj 20 20 r~ pc-dry;
#X obj 20 50 delwrite~ pc-pitch-memory 500;
#X obj 180 20 r pc-pitch;
#X obj 180 50 expr (1-pow(2\,$f1/12))*12.5;
