#N canvas 60 60 480 340 10;
#X obj 30 30 r pc-mode;
#X obj 30 60 == \$1;
#X obj 30 90 sel 0 1;
#X obj 150 130 t b b;
#X msg 150 170 1;
#X msg 250 170 stop;
#X obj 30 130 del 60;
#X msg 30 200 0;
#X obj 30 250 outlet;
#X text 180 30 mode-gated DSP switch: outputs 1 when pc-mode == \$1 \,
else 0 after a 60ms tail so the output crossfade in pt-output finishes
before DSP stops;
#X obj 150 250 outlet;
#X connect 0 0 1 0;
#X connect 1 0 2 0;
#X connect 2 0 6 0;
#X connect 2 1 3 0;
#X connect 3 0 4 0;
#X connect 3 1 5 0;
#X connect 4 0 8 0;
#X connect 5 0 6 0;
#X connect 6 0 7 0;
#X connect 7 0 8 0;
#X connect 1 0 10 0;
